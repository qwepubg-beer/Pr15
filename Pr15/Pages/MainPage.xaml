<Page x:Class="Pr15.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr15.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="400" d:DesignWidth="800"
      Title="MainPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
       <Label Grid.Row="0" Grid.ColumnSpan="2" Content="Собери свой ПК" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="26" />
        <Button  Grid.Row="1" Height="50" Content="Выбери процессор" Click="Button_Click"></Button>
        <Button  Grid.Row="2" Height="50" Content="Выбери мать"></Button>
        <Button  Grid.Row="3" Height="50" Content="Выбери блок питания"></Button>
        <Button  Grid.Row="4" Height="50" Content="Выбери корпус"></Button>
        <Button  Grid.Row="5" Height="50" Content="Выбери видиокарту"></Button>
        <Button  Grid.Row="6" Height="50" Content="Выбери оперативную память"></Button>
        <Button  Grid.Row="7" Height="50" Content="Выбери диск"></Button>
        <Button  Grid.Row="8" Height="50" Content="Выбери кулер для процессора"></Button>
        <TextBlock  Name ="Price" Grid.Row="0" Grid.Column="2" Text="Цена: " VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="20"/>
        <TextBlock  Name ="CPU" Grid.Row="1" Grid.Column="1" Text="Выбрано: " VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="20"/>
        <TextBlock  Grid.Row="2" Grid.Column="1" Text="Выбрано: " VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="20"/>
        <TextBlock  Grid.Row="3" Grid.Column="1" Text="Выбрано: " VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="20"/>
        <TextBlock  Grid.Row="4" Grid.Column="1" Text="Выбрано: " VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="20"/>
        <TextBlock  Grid.Row="5" Grid.Column="1" Text="Выбрано: " VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="20"/>
        <TextBlock  Grid.Row="6" Grid.Column="1" Text="Выбрано: " VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="20"/>
        <TextBlock  Grid.Row="7" Grid.Column="1" Text="Выбрано: " VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="20"/>
        <TextBlock  Grid.Row="8" Grid.Column="1" Text="Выбрано: " VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="20"/>
    </Grid>
</Page>
