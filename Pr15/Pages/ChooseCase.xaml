<Page x:Class="Pr15.Pages.ChooseCase"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr15.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ChooseCase">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="7*"/>
        </Grid.RowDefinitions>
        <ListBox x:Name="CaseList"  ScrollViewer.HorizontalScrollBarVisibility="Disabled" d:ItemsSource="{d:SampleData ItemCount=5}" Grid.Row="1" Grid.ColumnSpan="3" SelectionChanged="CaseList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel HorizontalAlignment="Center">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Padding="5" Text="{Binding name}" TextWrapping="Wrap"/>
                            <TextBlock Padding="5" Text="{Binding basepart.price, StringFormat=Цена: {0}}"/>
                        </StackPanel>
                        <Button Height="40" Content="Выбрать" Click="Button_Click"></Button>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
        <Button Content="Поиск" HorizontalAlignment="Center" VerticalAlignment="Center" Width="100" Grid.Column="1" Height="30" MaxWidth="200" MaxHeight="60" Click="Button_Click_1"/>
        <TextBox Name="TextSearch" HorizontalAlignment="Left" TextWrapping="Wrap" Text="" VerticalAlignment="Center"  Width="200" Height="30" Grid.Column="0" MaxWidth="400" MaxHeight="60"/>
    </Grid>
</Page>
