<Page x:Class="Pr15.Pages.EndPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr15.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EndPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Image Grid.Column="2" Grid.Row="0" Grid.RowSpan="9"  Source="/comp.jpg" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <TextBox Name="Name" Grid.Column="1" Grid.Row="1"></TextBox>
        <TextBox Name="Autor" Grid.Column="1" Grid.Row="2"></TextBox>
        <TextBlock Grid.Column="0" Grid.Row="1" Text="Name" FontSize="24" HorizontalAlignment="Center"></TextBlock>
        <TextBlock Grid.Column="0" Grid.Row="2" Text="Autor" FontSize="24" HorizontalAlignment="Center"></TextBlock>
        <Button  Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2" Content="Добавить" Click="Button_Click"></Button>
    </Grid>
</Page>
